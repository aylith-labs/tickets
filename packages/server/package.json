{
	"name": "@aylith/tickets-server",
	"version": "0.1.3",
	"description": "Hono daemon and CLI for @aylith/tickets — REST API, SSE, terminal launch, AI enrich, media pipeline",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"bun": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./cli": {
			"bun": "./src/cli.ts",
			"import": "./dist/cli.js"
		}
	},
	"bin": {
		"tickets": "./dist/cli.js"
	},
	"files": [
		"dist",
		"src",
		"!src/test"
	],
	"engines": {
		"bun": ">=1.2.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aylith-labs/tickets.git",
		"directory": "packages/server"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup && tsc -p tsconfig.json",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "0.110.0",
		"@aylith/tickets-core": "workspace:*",
		"hono": "4.12.28"
	},
	"devDependencies": {
		"tsup": "8.5.1",
		"typescript": "7.0.2"
	}
}
