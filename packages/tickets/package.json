{
	"name": "@aylith/tickets",
	"version": "0.1.1",
	"description": "Everything-in-one package for @aylith/tickets — daemon + CLI, terminal UI, web components, and core types via subpath exports",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"bun": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"bun": "./src/client.ts",
			"import": "./dist/client.js"
		},
		"./ui": {
			"types": "./dist/ui.d.ts",
			"bun": "./src/ui.ts",
			"import": "./dist/ui.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"bun": "./src/server.ts",
			"import": "./dist/server.js"
		}
	},
	"bin": {
		"tickets": "./bin/tickets.js",
		"tickets-tui": "./bin/tickets-tui.js"
	},
	"files": [
		"bin",
		"dist"
	],
	"engines": {
		"bun": ">=1.2.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aylith-labs/tickets.git",
		"directory": "packages/tickets"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup && tsc -p tsconfig.json",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@aylith/tickets-core": "workspace:*",
		"@aylith/tickets-server": "workspace:*",
		"@aylith/tickets-tui": "workspace:*",
		"@aylith/tickets-ui": "workspace:*"
	},
	"devDependencies": {
		"tsup": "8.5.1",
		"typescript": "7.0.2"
	}
}
