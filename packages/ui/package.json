{
	"name": "@aylith/tickets-ui",
	"version": "0.1.1",
	"description": "Framework-agnostic Lit web components for @aylith/tickets — themeable via CSS custom properties",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"bun": "./src/index.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aylith-labs/tickets.git",
		"directory": "packages/ui"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup && tsc -p tsconfig.json",
		"dev": "tsup --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@aylith/tickets-core": "workspace:*",
		"lit": "3.3.3"
	},
	"devDependencies": {
		"tsup": "8.5.1",
		"typescript": "7.0.2"
	}
}
